/.bundle/
/.yardoc
/_yardoc/
/coverage/
/doc/
/pkg/
/spec/reports/
/tmp/

# rspec failure tracking
.rspec_status

# Gemfile.lock MUST NOT be committed. A single lockfile resolved on one Ruby
# cannot serve the CRuby 3.1-3.4 + JRuby matrix (transitive dev-dep Ruby floors
# differ; JRuby needs the universal-java platform). ruby/setup-ruby@v1 with
# bundler-cache: true runs `bundle lock` per matrix job when no lockfile is
# present, giving each leg an engine/version-compatible resolution.
/Gemfile.lock

# Built gem artifacts (gem-smoke job)
/*.gem

# Node release tooling (semantic-release) is DEV-ONLY and runs on the CI runner.
# package.json / release.config.mjs / yarn.lock / .yarnrc.yml ARE committed
# (they configure the release pipeline and pin the dev toolchain — the PHP/
# Android SDKs commit their lockfile too, so `yarn install --immutable` is
# reproducible). The installed dependency tree and the Yarn Berry cache must
# never be committed; the gem keeps zero runtime deps and ships no Node files.
/node_modules/
/package-lock.json
/.yarn/
/.pnp.*
