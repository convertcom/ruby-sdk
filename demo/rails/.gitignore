# Gemfile.lock MUST NOT be committed for the demo. A single lockfile resolved on
# one Ruby cannot serve the CRuby 3.1-3.4 + JRuby CI matrix (transitive dev-dep
# Ruby floors differ; JRuby needs the universal-java platform). ruby/setup-ruby
# with bundler-cache runs `bundle lock` per matrix job when no lockfile is
# present, giving each leg an engine/version-compatible resolution. Same
# rationale as the gem's own .gitignore.
/Gemfile.lock

# Standard Rails ignores
/.bundle/
/log/*
/tmp/*
!/log/.keep
!/tmp/.keep

# Demo runtime / build artifacts
*.gem

# Never commit real env/secrets; keep the example tracked.
/.env
/.env.*
!/.env.example
