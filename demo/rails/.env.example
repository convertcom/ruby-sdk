# Convert Rails demo — environment configuration example.
#
# Copy to `.env` and fill in for INTERACTIVE (live-staging) mode:
#   cp .env.example .env   # then `docker compose up`
#
# The OFFLINE CI fork smoke (script/fork_smoke.rb) does NOT use these — it points
# the SDK at a local stub serving a canned config and uses canned entity keys, so
# it needs no real staging credentials.

# ── Credentials (same env-var names as the Story 5.1 staging suite) ──────────
# The SDK key + secret for the SHARED Convert staging project — the same project
# the JS/PHP demos use. Obtain these from the shared staging project.
CONVERT_SDK_KEY=<set-from-staging-project>
CONVERT_SDK_KEY_SECRET=<set-from-staging-project>

# ── Entity keys (the SAME entities the JS/PHP demos exercise) ────────────────
# Set these to the staging project's actual configured entity keys. (No live
# staging access in the sandbox where this demo was authored — these are
# PLACEHOLDERS; replace with the real keys from the shared staging project.)
CONVERT_PRICING_EXPERIENCE_KEY=<set-from-staging-project>   # the pricing A/B experience
CONVERT_FEATURE_KEY=<set-from-staging-project>              # the feature flag with typed variables
CONVERT_SEGMENT_KEY=<set-from-staging-project>              # a report segment
CONVERT_GOAL_KEY=<set-from-staging-project>                 # the purchase/revenue goal

# ── Optional ─────────────────────────────────────────────────────────────────
# Platform environment selector passed as a visitor attribute (audience gating).
CONVERT_ENVIRONMENT=staging
# Demo purchase amount used as the conversion's revenue goal_data.
CONVERT_DEMO_PURCHASE_AMOUNT=49.99

# ── Offline-smoke-only knobs (set by script/fork_smoke.rb; leave UNSET for live)
# CONVERT_CONFIG_ENDPOINT  — override the config-fetch base URL (-> local stub)
# CONVERT_TRACK_ENDPOINT   — override the track base URL (-> local stub)
# CONVERT_DEMO_TIMERS_OFF  — "1" turns timers off + flushes per request (deterministic)
