# Convert Rails demo — environment configuration example.
#
# YOU DO NOT NEED A .env TO RUN THIS DEMO. By default (no .env, no env vars) the
# demo runs in OFFLINE direct-data mode against a committed config fixture — zero
# credentials, zero network, fully deterministic. Copy this file to `.env` ONLY if
# you want to run against the shared live-staging project (LIVE mode).
#
#   # OFFLINE (default): nothing to do — just boot.
#   docker compose up        # or: bundle exec puma -C config/puma.rb
#
#   # LIVE (opt-in): copy + uncomment the LIVE block below, then boot.
#   cp .env.example .env
#
# .env is gitignored (see .gitignore) — never commit real credentials.

# ── OFFLINE mode (DEFAULT — these are the working defaults; nothing required) ──
# OFFLINE mode is selected automatically when BOTH CONVERT_SDK_KEY and
# CONVERT_CONFIG_ENDPOINT are unset. The SDK is built via direct-data mode from
# config/convert_demo_config.json (account 10022898) — no fetch. The controller's
# entity-key defaults are that fixture's real keys, so an empty .env "just works":
#
#   CONVERT_PRICING_EXPERIENCE_KEY=test-experience-ab-fullstack-2
#   CONVERT_FEATURE_KEY=feature-1
#   CONVERT_SEGMENT_KEY=test-segments-1
#   CONVERT_GOAL_KEY=goal-without-rule
#
# Optional offline knobs:
# CONVERT_DEMO_PURCHASE_AMOUNT=49.99   # revenue goal_data on the tracked conversion
# CONVERT_LOG_LEVEL=trace              # attach a stdout SDK logger (trace/debug/info/…)

# ── LIVE mode (opt-in — uncomment to run against the shared staging project) ──
# Setting CONVERT_SDK_KEY switches the demo to LIVE mode (real config fetch +
# track). The shared staging project is 10035569/10034190 — the SAME project the
# JS/PHP demos use. NOTE: this key needs NO secret (the public account/project key
# pair suffices; the SDK only requires sdk_key OR data, and the Story 5.1 staging
# suite sends a secret only when one is present). Leave CONVERT_SDK_KEY_SECRET
# unset for the shared key, mirroring the php-sdk demo's .env.example.
#
# CONVERT_SDK_KEY=10035569/10034190
# # CONVERT_SDK_KEY_SECRET=        # leave UNSET for the shared staging key (no secret)
#
# # LIVE entity keys — the php-sdk demo's verified shared-staging entities. These
# # are the controller's LIVE defaults too, so they're optional to set here.
# CONVERT_PRICING_EXPERIENCE_KEY=test-experience-ab-fullstack-1   # the pricing A/B experience
# CONVERT_FEATURE_KEY=feature-5                                   # feature flag with typed variables
# CONVERT_SEGMENT_KEY=test-segment-1                              # a report segment
# CONVERT_GOAL_KEY=button-primary-click                          # the conversion goal
#
# # Platform environment selector passed as a visitor attribute (audience gating).
# CONVERT_ENVIRONMENT=staging
# # Demo purchase amount used as the conversion's revenue goal_data.
# CONVERT_DEMO_PURCHASE_AMOUNT=49.99

# ── Offline-smoke-only knobs (set by script/fork_smoke.rb; leave UNSET otherwise)
# These point the SDK at the fork smoke's local stub server. Setting
# CONVERT_CONFIG_ENDPOINT (like CONVERT_SDK_KEY) takes the demo OUT of OFFLINE
# direct-data mode and into the sdk_key+endpoint path the smoke relies on.
# CONVERT_CONFIG_ENDPOINT  — override the config-fetch base URL (-> local stub)
# CONVERT_TRACK_ENDPOINT   — override the track base URL (-> local stub)
# CONVERT_DEMO_TIMERS_OFF  — "1" turns timers off + flushes per request (deterministic)
