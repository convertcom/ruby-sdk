module ConvertSdk
  # The default config-cache TTL in seconds for the timer-off lazy-TTL fallback.
  DEFAULT_CONFIG_TTL: Integer

  # The SDK's base error type (namespace anchor; no runtime exception hierarchy).
  class Error < StandardError
  end

  self.@at_exit_registration_enabled: bool

  # Whether Client registers its PID-guarded at_exit flush (Story 4.4 AC#5).
  # Always true in production; the test harness alone flips it off.
  def self.at_exit_registration_enabled?: () -> bool

  def self.at_exit_registration_enabled=: (bool value) -> bool

  # Build an SDK client from an SDK key (fetch) or a pre-fetched data object.
  def self.create: (?sdk_key: String?, ?data: Hash[untyped, untyped]?, ?store: untyped?, ?clock: (^() -> Float)?, **untyped options) -> Client

  # Build the DataManager wired with the Story 2.7 config-cache surface.
  def self.build_data_manager: (Config config, LogManager log_manager, DataStoreManager data_store_manager, (^() -> Float)? clock) -> DataManager

  # Build the outbound delivery surface (Story 4.1 ApiManager).
  def self.build_api_manager: (Config config, LogManager log_manager, HttpClient http_client, EventManager event_manager, DataManager data_manager) -> ApiManager
end
