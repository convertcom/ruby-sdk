module ConvertSdk
  # The in-memory home of the deep-frozen project config snapshot and the only
  # surface through which config is read.
  class DataManager
    @log_manager: LogManager
    @data_store_manager: DataStoreManager?
    @config_key: String?
    @ttl: Numeric?
    @timer_off: bool
    @clock: ^() -> Float
    @config: Hash[String, untyped]?
    @fetched_at: Float?
    @config_mutex: Thread::Mutex
    @fetch_mutex: Thread::Mutex

    attr_accessor refetch: (^() -> untyped)?

    def initialize: (
      log_manager: LogManager,
      ?data_store_manager: DataStoreManager?,
      ?config_key: String?,
      ?ttl: Numeric?,
      ?clock: ^() -> Float,
      ?refetch: (^() -> untyped)?
    ) -> void

    def install_config: (untyped hash) -> (Symbol | bool)

    def install_from_cache_if_fresh: () -> Symbol?

    def ensure_fresh_config!: () -> void

    def config_stale?: () -> bool

    def config_available?: () -> bool

    def account_id: () -> String?

    def project_id: () -> String?

    def project: () -> Hash[String, untyped]?

    def experiences: () -> Array[untyped]

    def features: () -> Array[untyped]

    def goals: () -> Array[untyped]

    def audiences: () -> Array[untyped]

    def segments: () -> Array[untyped]

    def locations: () -> Array[untyped]

    def experience_by_key: (String key) -> Hash[String, untyped]?

    def feature_by_key: (String key) -> Hash[String, untyped]?

    def goal_by_key: (String key) -> Hash[String, untyped]?

    private

    def cache_config: (Hash[String, untyped] frozen) -> void

    def cached_entry: () -> Hash[String, untyped]?

    def effective_ttl: () -> Numeric

    def data: () -> Hash[String, untyped]?

    def collection: (String name) -> Array[untyped]

    def find_by_key: (Array[untyped] list, String key) -> Hash[String, untyped]?

    def deep_freeze: (untyped node) -> untyped
  end
end
