    {
      "category": "nested_hierarchy",
      "description": "Full OR → AND → OR_WHEN hierarchy",
      "data": { "device": "tablet", "browser": "safari", "age": 31 },
      "ruleSet": {
        "OR": [
          {
            "AND": [
              {
                "OR_WHEN": [
                  {
                    "rule_type": "generic_key_value",
                    "matching": { "match_type": "isIn", "negated": false },
                    "value": "phone|tablet",
                    "key": "device"
                  }
                ]
              },
              {
                "OR_WHEN": [
                  {
                    "rule_type": "generic_key_value",
                    "matching": { "match_type": "equals", "negated": false },
                    "value": "safari",
                    "key": "browser"
                  }
                ]
              }
            ]
          },
          {
            "AND": [
              {
                "OR_WHEN": [
                  {
                    "rule_type": "generic_key_value",
                    "matching": { "match_type": "less", "negated": true },
                    "value": 30,
                    "key": "age"
                  }
                ]
              }
            ]
          }
        ]
      },
      "expected": true
